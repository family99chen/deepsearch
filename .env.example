# API and queue
API_PORT=8080
REDIS_PORT=6379
MONGODB_PORT=27018
JOB_TTL_SECONDS=604800

# API process guard. Worker-side Chromium concurrency is controlled by config.yaml.
PIPELINE_MAX_CONCURRENT=10

# Start low because each Celery task can spawn multiple Chromium subprocesses.
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
WORKER_SHM_SIZE=1gb

# Optional when using a remote Redis instead of the compose redis service.
# REDIS_URL=redis://redis-host:6379/0
# CELERY_BROKER_URL=redis://redis-host:6379/0
# CELERY_RESULT_BACKEND=redis://redis-host:6379/0

# Optional when using a remote MongoDB instead of the compose mongo service.
# MONGODB_URL=mongodb://mongo-host:27018/
# MONGODB_DB_NAME=deepsearch_cache
# MONGODB_USERNAME=
# MONGODB_PASSWORD=
# MONGODB_AUTH_SOURCE=admin
